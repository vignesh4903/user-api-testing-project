          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"resource created succesfully\",function(){\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "let jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"ID Exist\",function(){\r",
              "    pm.expect(jsonData.id).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"Name exist\",function(){\r",
              "    pm.expect(jsonData.name).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"Name is correct\",function(){\r",
              "    pm.expect(jsonData.name).to.eql(\"vignesh\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
